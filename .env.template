# wAether Environment Configuration Template
# Copy this file to .env and fill in the actual values
# Never commit .env files to version control

# =============================================================================
# FIREBASE CONFIGURATION
# =============================================================================
# Firebase project configuration - obtain from Firebase Console
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_APP_ID=your-firebase-app-id
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id

# =============================================================================
# EXTERNAL API KEYS
# =============================================================================
# OpenMeteo API (Free tier available, no key required for basic usage)
# For production usage with higher limits, register at: https://openmeteo.com/
OPENMETEO_API_KEY=optional-for-basic-usage

# NOAA Space Weather Prediction Center API
# Free public API, no key required
# API Documentation: https://www.swpc.noaa.gov/products
NOAA_SWPC_BASE_URL=https://services.swpc.noaa.gov

# =============================================================================
# GOOGLE SERVICES
# =============================================================================
# Google Play Services Location API
# Configured through google-services.json file
GOOGLE_SERVICES_ENABLED=true

# =============================================================================
# DEBUGGING AND LOGGING
# =============================================================================
# Enable debug logging (set to false in production)
DEBUG_LOGGING=true

# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=DEBUG

# Enable network request logging (disable in production for security)
NETWORK_LOGGING=true

# =============================================================================
# WEAR OS SPECIFIC CONFIGURATION
# =============================================================================
# Data refresh intervals (in milliseconds)
DATA_REFRESH_INTERVAL_MS=300000
GLOBAL_SNAPSHOT_INTERVAL_HOURS=6

# Background worker configuration
ENABLE_BACKGROUND_WORKERS=true

# =============================================================================
# PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Set to 'production' for production deployments
ENVIRONMENT=development

# Enable crash reporting (requires additional setup)
CRASH_REPORTING_ENABLED=false

# Performance monitoring
PERFORMANCE_MONITORING_ENABLED=false