# wAether Environment Configuration Template
# Copy this file to .env and configure your settings

# Firebase Configuration
# Create a Firebase project and add your configuration here
# Note: google-services.json file is also required in app/ directory

# API Configuration
# OpenMeteo API (no key required)
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1/

# NOAA Space Weather Prediction Center API (no key required)
NOAA_SWPC_BASE_URL=https://services.swpc.noaa.gov/

# Development Settings
DEBUG_LOGGING_ENABLED=true
MOCK_SENSOR_DATA=false

# Network Configuration
HTTP_TIMEOUT_SECONDS=30
RETRY_ATTEMPTS=3

# Background Work Configuration
GLOBAL_SNAPSHOT_INTERVAL_HOURS=1
MOOD_LOG_SYNC_INTERVAL_HOURS=6

# Wear OS Specific
BATTERY_OPTIMIZATION_ENABLED=true
REDUCE_ANIMATIONS=false

# Testing Configuration
ENABLE_TEST_MODE=false
MOCK_LOCATION_DATA=false